# ───────────────────────────────────────────────────────────────────────────
# Terramend — local dev / test environment
# ───────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` (same directory) and fill in what you need:
#
#   cp .env.example .env
#
# Loaded automatically by `dev-run.ts` (the `pnpm dev:run` harness) and by the
# vitest global setup. NEVER commit your real `.env`.
#
# Terramend is BYOK (bring your own key): you only need credentials for the
# ONE model provider you intend to use, plus a GitHub token if a run touches a
# repository. Everything here is optional — leave the rest blank.
# Internal runtime vars (TERRAMEND_TEMP_DIR, TERRAMEND_MCP_PORT, …) are set by
# the action itself and must NOT be configured here.


# ── 1. Model provider — pick ONE ────────────────────────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# …or a Claude Code OAuth token instead of an API key:
# CLAUDE_CODE_OAUTH_TOKEN=

# OpenAI
# OPENAI_API_KEY=

# Google Gemini (either name works)
# GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_API_KEY=

# Other direct providers
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# MOONSHOT_API_KEY=
# OPENROUTER_API_KEY=

# AWS Bedrock (set BEDROCK_MODEL_ID + TERRAMEND_MODEL=bedrock/byok to use)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=eu-west-2
# BEDROCK_MODEL_ID=         # EU inference profile, e.g. eu.anthropic.claude-sonnet-4-6

# Google Vertex (set VERTEX_MODEL_ID + TERRAMEND_MODEL=vertex/byok to use)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=
# VERTEX_LOCATION=europe-west2   # keep inference in-region (UK/EU); avoid the multi-region `global` endpoint
# VERTEX_MODEL_ID=


# ── 2. GitHub access — needed for runs that read a repo / open PRs ───────────

# Personal-access-token mode (simplest for local dev):
GH_TOKEN=
# GITHUB_TOKEN is also honored if GH_TOKEN is unset.

# …or GitHub App mode (use instead of a PAT):
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=


# ── 3. Optional overrides ────────────────────────────────────────────────────

# Force a specific model — "provider/model" or a registered alias.
# Overrides auto-selection; for Bedrock/Vertex BYOK use the "<provider>/byok" form.
# TERRAMEND_MODEL=anthropic/claude-opus

# Force a specific agent backend (auto-selected from the model otherwise):
#   claude | opencode
# TERRAMEND_AGENT=claude
